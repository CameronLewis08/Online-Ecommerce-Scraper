# PostgreSQL connection string

DATABASE_URL=postgresql://DB_USERNAME:DB_PASSWORD@localhost:5432/ecommerce_etl
DB_USERNAME=USERNAME
DB_PASSWORD=PASSWORD
DB_NAME=ecommerce_etl
DB_HOST=localhost


# Scraping config
SCRAPE_BASE_URL=https://books.toscrape.com
SCRAPE_INTERVAL_MINUTES=60
REQUEST_DELAY_SECONDS=1.0

# Logging
LOG_FILE=logs/pipeline.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3

# Database credentials for docker-compose (used by the API container to connect to the Postgres container)

POSTGRES_USER=DB_USERNAME
POSTGRES_PASSWORD=DB_PASSWORD